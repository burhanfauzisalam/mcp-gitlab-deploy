TRAEFIK_NETWORK=web
TRAEFIK_ENTRYPOINT=websecure
MAIN_DOMAIN=apps.burhanfs.my.id

DEPLOYMENT_DATA_DIR=./data/deployments
GITLAB_DEPLOYMENT_ROOT=/home/ubuntu/apps

MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_MOUNT_PATH=
MCP_SSE_PATH=/sse
# Optional: host/origin allowlist untuk proteksi Host header (421).
# MAIN_DOMAIN otomatis diizinkan. Tambahan host pisahkan dengan koma.
MCP_ALLOWED_HOSTS=
# Optional: origin allowlist tambahan (comma-separated).
MCP_ALLOWED_ORIGINS=
# Optional: paksa enable/disable proteksi DNS rebinding (true/false).
# Jika kosong, otomatis aktif bila MAIN_DOMAIN atau MCP_ALLOWED_HOSTS terisi.
MCP_ENABLE_DNS_REBINDING_PROTECTION=

# Optional: token default untuk clone repo GitLab private via HTTPS.
GITLAB_ACCESS_TOKEN=
