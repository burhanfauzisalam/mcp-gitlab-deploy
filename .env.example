TRAEFIK_NETWORK=web
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_ROUTER_RULE=Host(`example.com`) && PathPrefix(`/gitlab-deploy`)

DEPLOYMENT_DATA_DIR=./data/deployments
GITLAB_DEPLOYMENT_ROOT=/home/ubuntu/apps

MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_MOUNT_PATH=
MCP_SSE_PATH=/sse

# Optional: token default untuk clone repo GitLab private via HTTPS.
GITLAB_ACCESS_TOKEN=
